{
  "watch": ["src", "workers", "simple_server.js", "sqliteInit.js"],
  "ext": "js,json",
  "ignore": ["src/**/*.test.js", "node_modules", "logs/*.log", "database.sqlite"],
  "exec": "node simple_server.js",
  "env": {
    "NODE_ENV": "development",
    "USE_SQLITE": "true",
    "PORT": "5001"
  }
}




