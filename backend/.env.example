# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5001
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────────────────
# Docker Compose sets these automatically. Override for external DB.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kill_metraj
DB_USER=postgres
DB_PASSWORD=changeme_in_production

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string

# ── Admin Seed ──────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme_on_first_login
SEED_ADMIN_EMAIL=admin@kill-metraj.com
SETUP_SECRET=change-this-setup-secret

# ── External Dashboard API ─────────────────────────────────────────────
EXTERNAL_API_URL=http://app.yaposhka.kh.ua:4999/api/v1/dashboard
EXTERNAL_API_KEY=your-api-key-here

# ── Frontend ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:80

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300
REDIS_STALE_TTL=600

# ── gRPC ────────────────────────────────────────────────────────────────
GRPC_PORT=50051

# ── Database Sync ───────────────────────────────────────────────────────
DB_ALTER_SYNC=false

# ── Routing (OSRM / Valhalla) ──────────────────────────────────────────
# Uncomment and set if using self-hosted routing stack:
# SELF_HOST_OSRM_URL=http://osrm:5000
# SELF_HOST_VALHALLA_URL=http://valhalla:8002
# NOMINATIM_URL=http://nominatim:8080
# REMOTE_OSRM_URL=http://116.204.153.171:5050
# REMOTE_VALHALLA_URL=http://valhalla.yapiko.kh.ua
# PHOTON_URL=https://photon.komoot.io
# YAPIKO_OSRM_URL=http://116.204.153.171:5050

# ── CDC / Kafka (optional) ─────────────────────────────────────────────
# CDC_ENABLED=false
# KAFKA_BROKER=kafka:9092
# KAFKA_TOPIC=kill_metraj.public.api_dashboard_cache

# ── Cache ───────────────────────────────────────────────────────────────
CACHE_MAX_ENTRIES=20
CACHE_MAX_SIZE_MB=8
